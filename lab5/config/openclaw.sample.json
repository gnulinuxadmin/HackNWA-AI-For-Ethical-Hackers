{
  "agent": {
    "workspace": "/workspace",
    "skill_dirs": ["skills"],
    "max_steps": 10,
    "step_timeout_seconds": 30
  },
  "models": {
    "providers": {
      "ollama": {
        "apiKey": "ollama-local",
        "baseUrl": "http://host.docker.internal:11434",
        "api": "ollama"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/llama3.2:3b",
        "fallbacks": []
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan"
  },
  "state": {
    "backend": "file",
    "path": "/lab5/state"
  }
}

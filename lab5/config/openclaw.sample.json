{
  "agent": {
    "workspace": "/workspace",
    "skill_dirs": ["skills"],
    "max_steps": 10,
    "step_timeout_seconds": 30,
    "model": "ollama/llama3.2:3b"
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan"
  },
  "state": {
    "backend": "file",
    "path": "/lab5/state"
  },
  "providers": {
    "ollama": {
      "baseUrl": "http://host.docker.internal:11434"
    }
  }
}
